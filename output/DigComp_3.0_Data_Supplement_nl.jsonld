      "competence_area_id": "CompetenceArea/1",
      "competence_id": "Competence/1.1",
      "four_levels_proficiency_name": "ProficiencyLevel/Basic",
      "description_nl": "Erkennen dat digitale zoekresultaten of output informatie kunnen bevatten die mogelijk niet relevant is, en dat deze afhankelijk zijn van de gebruikte digitale zoekmachine en de wijze waarop de zoekopdracht is gespecificeerd.",
      "four_levels_proficiency_name_nl": "Basis"
    },
    {
