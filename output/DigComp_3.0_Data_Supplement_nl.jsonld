      "four_levels_proficiency_name_nl": "Basis"
    },
    {
      "@type": "CompetenceStatement",
      "@id": "CompetenceStatement/CS1.1.02",
      "description": "Identify the main features of commonly-used AI-driven and traditional search tools.",
